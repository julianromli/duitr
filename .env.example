# Supabase Configuration (legacy — remove after Neon cutover)
# Get these values from your Supabase project dashboard
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Database provider: supabase (default) | neon
VITE_DATABASE_PROVIDER=neon

# Neon Auth + Data API (required when VITE_DATABASE_PROVIDER=neon)
VITE_NEON_AUTH_URL=https://ep-dry-shadow-aoulq0jd.neonauth.c-2.ap-southeast-1.aws.neon.tech/neondb/auth
VITE_NEON_DATA_API_URL=https://ep-dry-shadow-aoulq0jd.apirest.c-2.ap-southeast-1.aws.neon.tech/neondb/rest/v1

# AI function endpoint (defaults to same-origin TanStack Start route)
# VITE_AI_FUNCTION_URL=/api/ai/gemini-finance-insight

# Server-only (Wrangler secret / .dev.vars) — never prefix with VITE_
# GEMINI_API_KEY=your_gemini_api_key_here
#   Cloudflare: bunx wrangler secret put GEMINI_API_KEY
#   Local preview: copy .dev.vars.example to .dev.vars

# Application Configuration
VITE_APP_ENV=development
VITE_APP_VERSION=2.2.0
VITE_APP_NAME=Duitr

# Production Domain (for OAuth redirects)
VITE_PRODUCTION_DOMAIN=https://duitr.faizintifada.com

# Development Configuration
VITE_DEV_PORT=8080
VITE_PREVIEW_PORT=4173

# Security Headers (optional)
VITE_ENABLE_CSP=true

# Analytics (optional)
VITE_ANALYTICS_ID=

# Feature Flags (optional)
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE_MODE=true

# Instructions:
# 1. Copy this file to .env
# 2. Replace placeholder values with your credentials
# 3. Never commit the .env file to version control
# 4. Keep your credentials secure and rotate them regularly
